# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:pass@ep-rest-of-url.neon.tech/neondb"

# Queue (Upstash Redis)
UPSTASH_REDIS_URL="rediss://default:token@region.upstash.io:6379"
EMAIL_MAX_LIMIT=10
SMS_MAX_LIMIT=2
PUSH_MAX_LIMIT=50
EMAIL_CONCURRENCY=5
SMS_CONCURRENCY=2
PUSH_CONCURRENCY=10

# Email (ZeptoMail)
ZEPTOMAIL_API_KEY="your_zeptomail_key"
ZEPTOMAIL_SENDER_EMAIL="notifications@yourdomain.com"

# SMS (Twilio)
TWILIO_ACCOUNT_SID="your_sid"
TWILIO_AUTH_TOKEN="your_token"
TWILIO_PHONE_NUMBER="+1234567890"

# Push (OneSignal)
ONESIGNAL_APP_ID="your_app_id"
ONESIGNAL_REST_API_KEY="your_rest_key"
